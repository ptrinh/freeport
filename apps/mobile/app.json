{
  "expo": {
    "name": "Freeport",
    "slug": "freeport",
    "owner": "ptrinh",
    "version": "1.6.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "uk.trinh.freeport",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "21",
      "associatedDomains": [
        "webcredentials:freeport.network"
      ]
    },
    "android": {
      "package": "uk.trinh.freeport",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB70aRYEMJlBtl3LgvnBpGe6dkKuJhwJY4"
        }
      },
      "versionCode": 23
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-gemini-nano",
      "expo-asset",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Freeport uses your location to set your pickup point and show nearby rides and services."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Freeport needs photo access so you can attach pictures to your profile, listings and messages.",
          "cameraPermission": "Freeport needs camera access so you can take photos to attach to listings and messages."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Freeport uses the microphone so you can record and send voice messages."
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Freeport needs camera access for video calls and to take photos for listings and messages.",
          "microphonePermission": "Freeport uses the microphone for calls and voice messages."
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#06080c",
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#06080c",
            "image": "./assets/icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#3b82f6"
        }
      ],
      [
        "@sentry/react-native",
        {
          "url": "https://glitchtip.trinh.uk",
          "organization": "phil-t",
          "project": "freeport"
        }
      ],
      "@breeztech/breez-sdk-spark-react-native",
      [
        "expo-camera",
        {
          "cameraPermission": "Freeport uses the camera to scan payment QR codes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1c014d95-0907-4e4c-a65a-8beedf0fc805"
      },
      "webBase": "https://freeport.network"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1c014d95-0907-4e4c-a65a-8beedf0fc805",
      "disableAntiBrickingMeasures": true,
      "checkAutomatically": "ON_ERROR_RECOVERY"
    }
  }
}
