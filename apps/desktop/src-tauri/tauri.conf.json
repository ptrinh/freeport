{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freeport",
  "version": "1.5.0",
  "identifier": "network.freeport.desktop",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1RUY0RENBMTIzRjIxRDcKUldUWElUOFN5azN2RlJSVXc1OUI3dTV2T0hNekxSdkVZOHpueEM0eXNxajhYMStGUFpUUE1wVk0K",
      "endpoints": [
        "https://github.com/ptrinh/freeport/releases/latest/download/latest.json"
      ]
    }
  },
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run build:web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Freeport",
        "width": 1100,
        "height": 820,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "backgroundColor": "#06080c"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "deb",
      "nsis",
      "msi",
      "app",
      "dmg"
    ],
    "externalBin": [
      "binaries/freeport-notifier"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Decentralized P2P marketplace on Nostr",
    "longDescription": "Freeport is a decentralized peer-to-peer marketplace for rides, services and goods, built on Nostr. No middleman, no commission, no account. Includes an optional built-in server to host Freeport for others on your network."
  }
}
