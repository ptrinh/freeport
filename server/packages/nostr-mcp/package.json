{
  "name": "freeport-nostr-mcp",
  "version": "0.6.8",
  "description": "MCP server for searching Freeport Nostr events (ride requests, driver/provider offers, service & product posts, reputation) by kind, tag, and geohash radius.",
  "type": "module",
  "mcpName": "io.github.ptrinh/freeport-nostr",
  "bin": {
    "freeport-nostr-mcp": "dist/stdio.js"
  },
  "main": "dist/http.js",
  "files": ["dist", "README.md"],
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "expo-server-sdk": "^3.10.0",
    "express": "^5.1.0",
    "nostr-tools": "^2.10.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@freeport/protocol": "*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
