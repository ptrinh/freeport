# Copy to .env (docker compose reads it automatically) and edit.

# --- Server ---
HOST=0.0.0.0
PORT=8788

# --- Rate limits (per-IP + global token buckets) ---
RATE_LIMIT_PER_MIN=300
RATE_LIMIT_BURST=60
RATE_LIMIT_GLOBAL_PER_MIN=2500

# --- Relays ---
# Comma-separated relay URLs to query. Defaults to a built-in set if unset.
# FREEPORT_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net
# Max relays a single request may override (DoS guard).
# MAX_RELAYS=12

# --- Push notifier (set ENABLE_NOTIFY=0 to run an MCP-only server) ---
ENABLE_NOTIFY=1
DATA_DIR=/data
VAPID_SUBJECT=mailto:you@example.com
# Pin VAPID keys so browser push subscriptions survive a restart/volume wipe.
# Generate a pair:
#   docker compose run --rm freeport-nostr-mcp node -e "console.log(require('web-push').generateVAPIDKeys())"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
