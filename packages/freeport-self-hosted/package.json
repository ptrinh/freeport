{
  "name": "freeport-self-hosted",
  "version": "0.6.9",
  "description": "Self-hosted Freeport in a box: the web app + read-only MCP server + content-blind push notifier + Nostr relay + Telegram bridge, one process, default port 1988.",
  "type": "module",
  "mcpName": "io.github.ptrinh/freeport-nostr",
  "bin": {
    "freeport-self-hosted": "dist/stdio.js"
  },
  "main": "dist/http.js",
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "test": "vitest run",
    "build:web": "bash ./build-web.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "expo-server-sdk": "^3.10.0",
    "express": "^5.1.0",
    "nostr-tools": "^2.10.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@freeport/agent": "*",
    "@freeport/protocol": "*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
