# Copy to .env (git-ignored). Docker Compose REQUIRES this file to exist — an
# empty .env is fine: the notifier runs and the Telegram bridge stays OFF until
# you set a bot token. Non-secret tunables live in docker-compose.yml; secrets
# belong here.

# --- Web Push notifier (job 2) ---
# Pin VAPID keys so push subscriptions survive a volume wipe. Generate a pair:
#   docker compose run --rm freeport-nostr-mcp \
#     node -e "console.log(require('web-push').generateVAPIDKeys())"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# --- Telegram bridge (job 3, optional) ---
# Set the bot token (from @BotFather) to enable the feed + personal pings.
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_WEB_BASE=https://freeport.trinh.uk

# Guest-agent mode (CUSTODIAL): the bridge holds one NIP-49-encrypted key per
# Telegram-native user so they can post + deal without the app. Unset = OFF
# (feed + pings still work). Use a long, random passphrase. **Secret.**
# TELEGRAM_GUEST_KEY_PASSPHRASE=
# GUEST_COUNTRY_HINT=sg
