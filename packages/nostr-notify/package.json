{
  "name": "freeport-nostr-notify",
  "version": "0.1.0",
  "description": "Self-hostable, content-blind Web Push notifier for Freeport: watches Nostr relays and pushes new matching intents (by kind, topic, geohash radius) to subscribed browsers/PWAs — including iOS Home-Screen installs.",
  "type": "module",
  "bin": {
    "freeport-nostr-notify": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist", "README.md"],
  "license": "MIT",
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "nostr-tools": "^2.10.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@freeport/protocol": "*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
